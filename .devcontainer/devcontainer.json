{
  "name": "eegintent",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "runArgs": ["--gpus", "all"],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "charliermarsh.ruff",
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  },
  "postCreateCommand": "pip install -e .[dev] && pre-commit install",
  "remoteUser": "root"
}
